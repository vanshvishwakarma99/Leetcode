class Solution:
    def levelOrder(self, root: Optional[TreeNode]) -> List[List[int]]:
        Q = []
        res = []
        if root is not None:
            Q.append(root)
        while len(Q) != 0:
            node = len(Q)
            temp = []
            for i in range(node):
                node = Q.pop(0)
                if node.left is not None:
                    Q.append(node.left)
                if node.right is not None:
                    Q.append(node.right)
                temp.append(node.val)
            res.append(temp)
        return res
